# Conference MVP — local development environment
# Copy this file to .env and adjust values for your setup.
# The .env file is gitignored and must never be committed.

# ──────────────────────────────────────────────────────────────
# General
# ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ──────────────────────────────────────────────────────────────
# Production server identity
# Required when deploying with docker-compose.prod.yml.
# ──────────────────────────────────────────────────────────────
# DOMAIN=conference.example.com
# CERTBOT_EMAIL=admin@example.com

# ──────────────────────────────────────────────────────────────
# Public URLs — used by API (CORS, join URL) and the browser
# For desktop-only testing, keep the localhost defaults.
# For mobile testing, change all four to your LAN IP (see below).
# ──────────────────────────────────────────────────────────────
WEB_PUBLIC_URL=http://localhost:5173
MEDIA_NODE_ID=local
SIGNALING_PUBLIC_URL=ws://localhost:4000/ws

# Vite injects these into the browser bundle at build time (production) or
# dev-server startup (development). Both must point to addresses reachable
# from the browser (not Docker internals).
# Development defaults (localhost):
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_SIGNALING_URL=ws://localhost:4000/ws
# Production values — set these on the server before building:
# VITE_API_BASE_URL=https://conference.example.com/api/v1
# VITE_SIGNALING_URL=wss://conference.example.com/ws

# ──────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ──────────────────────────────────────────────────────────────
# mediasoup WebRTC
# MEDIASOUP_LISTEN_IP   — IP the signaling container listens on (keep 0.0.0.0)
# MEDIASOUP_ANNOUNCED_IP — IP the browser uses to reach media UDP ports.
#   localhost (127.0.0.1) works for desktop testing from the same machine.
#   For mobile, set this to your LAN IP (e.g. 192.168.1.100).
# ──────────────────────────────────────────────────────────────
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100
# Number of mediasoup worker processes. Compose defaults to 2 for local development.
# For the 2-core MVP server, set MEDIASOUP_NUM_WORKERS=1 in the server .env.
# MEDIASOUP_NUM_WORKERS=2
MEDIASOUP_MAX_TRANSPORTS_PER_PEER=4
MEDIASOUP_MAX_PRODUCERS_PER_PEER=3
MEDIASOUP_MAX_CONSUMERS_PER_PEER=32

# ──────────────────────────────────────────────────────────────
# TURN / STUN (coturn)
# Development credentials only — change before any public exposure.
# TURN_URL / TURN_USERNAME / TURN_PASSWORD are reserved for when
# the signaling service sends ICE server config to clients.
# ──────────────────────────────────────────────────────────────
TURN_URL=turn:localhost:3478
TURN_USERNAME=conference
TURN_PASSWORD=conference
TURN_REALM=conference.local

# ──────────────────────────────────────────────────────────────
# Security
# Must match between api and signaling services.
# Change to a random 32+ character value before any public exposure.
# ──────────────────────────────────────────────────────────────
JOIN_TOKEN_SECRET=change-me-for-local-development

# Signaling WebSocket runtime guardrails.
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_PAYLOAD_BYTES=65536
WS_SEND_BACKPRESSURE_BYTES=262144
WS_RATE_LIMIT_WINDOW_MS=10000
WS_RATE_LIMIT_MAX_MESSAGES=60
WS_ALLOWED_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────────────────────────
# Mobile testing — LAN IP override
# When testing from a physical phone:
#   1. Find your host LAN IP:  Windows: ipconfig | Linux/Mac: ip addr / ifconfig
#   2. Uncomment and set LAN_IP below, then replace all four overrides.
#   3. Run: docker compose down && docker compose up --build
#   4. On the phone, navigate to http://LAN_IP:5173
#
# LAN_IP=192.168.1.100
#
# MEDIASOUP_ANNOUNCED_IP=${LAN_IP}
# WEB_PUBLIC_URL=http://${LAN_IP}:5173
# MEDIA_NODE_ID=local
# SIGNALING_PUBLIC_URL=ws://${LAN_IP}:4000/ws
# WS_ALLOWED_ORIGINS=http://${LAN_IP}:5173
# VITE_API_BASE_URL=http://${LAN_IP}:3000/api/v1
# VITE_SIGNALING_URL=ws://${LAN_IP}:4000/ws
# TURN_URL=turn:${LAN_IP}:3478
# ──────────────────────────────────────────────────────────────
